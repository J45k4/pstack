{
  "name": "pstack",
  "version": "0.0.1",
  "module": "pstack/index.ts",
  "type": "module",
  "bin": {
    "pstack": "./cli/index.ts"
  },
  "exports": {
    ".": "./pstack/index.ts",
    "./database": "./pstack/database.ts",
    "./event-bus": "./pstack/event-bus.ts",
    "./react": "./pstack/react.ts",
    "./store": "./pstack/store.ts"
  },
  "scripts": {
    "example:todo": "bun --hot examples/todo/server.ts",
    "test": "bun test",
    "prepublishOnly": "bun test && bunx tsc --noEmit"
